{
  "expo": {
    "name": "Neetu Collection",
    "slug": "accounts",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F0F14"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.veer.neetucollection"
    },
    "android": {
      "package": "com.veer.neetucollection",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "1499d2a5-e7d0-4c92-8c79-47541ceb3f45"
      }
    },
    "owner": "veer.0p"
  }
}